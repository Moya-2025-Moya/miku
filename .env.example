# Required
ANTHROPIC_API_KEY=sk-ant-...

# Required for persistent profiles/memory (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — override model selection
ANALYSIS_MODEL=claude-sonnet-4-6        # upgrade to claude-opus-4-8 for max effort
IMPORT_MODEL=claude-haiku-4-5-20251001
ANALYSIS_EFFORT=medium                  # low | medium | high (medium = best speed/quality for demo)
